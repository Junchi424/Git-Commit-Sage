# ── API 配置 ──────────────────────────────
# 必填: 你的 API Key (Ollama 除外)
API_KEY=你的API_KEY

# 可选: 提供商 (openai / deepseek / ollama)
PROVIDER=openai

# 可选: API 地址 (留空则使用提供商默认地址)
# API_URL=https://api.openai.com/v1/chat/completions

# 可选: 模型名称 (留空则使用提供商默认模型)
# MODEL=gpt-4o-mini

# 可选: 自定义系统 prompt
# SYSTEM_PROMPT=你是一个 Git 提交信息助手...

# ── Ollama 配置 ──────────────────────────
# OLLAMA_HOST=http://localhost:11434

# ── 其他 ─────────────────────────────────
# TIMEOUT=60
